<Window x:Class="CyberSecurityAwarenessBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberSecurity Awareness Bot"
        Height="700"
        Width="1200"
        WindowStartupLocation="CenterScreen">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0"
                Background="#0F172A">

            <StackPanel>

                <TextBlock Text="🛡 Cyber Bot"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="20"/>

                <Button Name="ChatButton"
                        Content="Chat"
                        Height="45"
                        Margin="10"/>

                <Button Name="TasksButton"
                        Content="Tasks"
                        Height="45"
                        Margin="10"/>

                <Button Name="QuizButton"
                        Content="Quiz"
                        Height="45"
                        Margin="10"/>

                <Button Name="LogButton"
                        Content="Activity Log"
                        Height="45"
                        Margin="10"/>

            </StackPanel>

        </Border>

        <!-- Main Content -->

        <Grid Grid.Column="1">

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>

            <ListBox Name="ChatHistory"
                     Margin="15"/>

            <Grid Grid.Row="1">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>

                <TextBox Name="MessageTextBox"
                         Margin="10"
                         VerticalContentAlignment="Center"/>

                <Button Grid.Column="1"
                        Name="SendButton"
                        Content="Send"
                        Margin="10"/>

            </Grid>

        </Grid>

    </Grid>

</Window>