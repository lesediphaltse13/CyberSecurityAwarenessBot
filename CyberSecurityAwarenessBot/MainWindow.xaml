<Window x:Class="CyberSecurityAwarenessBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberSecurity Awareness Bot"
        Height="700"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#0B1120">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="8"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E5E7EB"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT MENU -->
        <Border Grid.Column="0" Background="#020617">
            <StackPanel Margin="10">

                <TextBlock Text="🛡 Cyber Bot"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="10,20,10,5"/>

                <TextBlock Text="Cybersecurity Awareness Assistant"
                           FontSize="12"
                           Foreground="#94A3B8"
                           Margin="10,0,10,30"
                           TextWrapping="Wrap"/>

                <Button Name="ChatButton"
                        Content="Chat"
                        Height="45"
                        Click="ChatButton_Click"/>

                <Button Name="TasksButton"
                        Content="Task Assistant"
                        Height="45"
                        Click="TasksButton_Click"/>

                <Button Name="QuizButton"
                        Content="Quiz"
                        Height="45"
                        Click="QuizButton_Click"/>

                <Button Name="LogButton"
                        Content="Activity Log"
                        Height="45"
                        Click="LogButton_Click"/>

            </StackPanel>
        </Border>

        <!-- MAIN AREA -->
        <Grid Grid.Column="1" Margin="20">

            <!-- CHAT PANEL -->
            <Grid Name="ChatPanel">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="70"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Chatbot Conversation"
                           FontSize="28"
                           FontWeight="Bold"
                           Margin="0,0,0,15"/>

                <ListBox Name="ChatHistory"
                         Grid.Row="1"
                         Background="#F8FAFC"
                         Foreground="Black"
                         FontSize="14"
                         Margin="0,0,0,15"/>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Name="MessageTextBox"
                             Height="45"
                             VerticalContentAlignment="Center"/>

                    <Button Grid.Column="1"
                            Name="SendButton"
                            Content="Send"
                            Height="45"
                            Click="SendButton_Click"/>
                </Grid>
            </Grid>

            <!-- TASK PANEL -->
            <Grid Name="TaskPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Cybersecurity Task Assistant"
                           FontSize="28"
                           FontWeight="Bold"
                           Margin="0,0,0,15"/>

                <Border Grid.Row="1"
                        Background="#111827"
                        Padding="15"
                        Margin="0,0,0,15">

                    <StackPanel>
                        <TextBlock Text="Task Title"/>
                        <TextBox Name="TaskTitleTextBox"
                                 Height="35"
                                 Margin="0,5,0,10"/>

                        <TextBlock Text="Description"/>
                        <TextBox Name="TaskDescriptionTextBox"
                                 Height="55"
                                 Margin="0,5,0,10"/>

                        <TextBlock Text="Reminder Date"/>
                        <DatePicker Name="ReminderDatePicker"
                                    Height="35"
                                    Margin="0,5,0,10"/>

                        <Button Content="Add Task"
                                Height="40"
                                Width="150"
                                HorizontalAlignment="Left"
                                Click="AddTaskButton_Click"/>
                    </StackPanel>
                </Border>

                <DataGrid Name="TasksDataGrid"
                          Grid.Row="2"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Margin="0,0,0,15">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding TaskId}" Width="60"/>
                        <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="200"/>
                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                        <DataGridTextColumn Header="Reminder" Binding="{Binding ReminderDate}" Width="170"/>
                        <DataGridCheckBoxColumn Header="Done" Binding="{Binding IsCompleted}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="3" Orientation="Horizontal">
                    <Button Content="Refresh Tasks"
                            Width="130"
                            Height="40"
                            Click="RefreshTasksButton_Click"/>

                    <Button Content="Complete Selected"
                            Width="160"
                            Height="40"
                            Click="CompleteTaskButton_Click"/>

                    <Button Content="Delete Selected"
                            Width="150"
                            Height="40"
                            Click="DeleteTaskButton_Click"/>
                </StackPanel>
            </Grid>

            <!-- QUIZ PANEL -->
            <Grid Name="QuizPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Cybersecurity Quiz"
                           FontSize="28"
                           FontWeight="Bold"
                           Margin="0,0,0,15"/>

                <TextBlock Name="QuizStatusTextBlock"
                           Grid.Row="1"
                           Text="Click Start Quiz to begin."
                           FontSize="16"
                           Foreground="#CBD5E1"
                           Margin="0,0,0,20"/>

                <Border Grid.Row="2"
                        Background="#111827"
                        Padding="20"
                        Margin="0,0,0,15">

                    <StackPanel>
                        <TextBlock Name="QuestionTextBlock"
                                   TextWrapping="Wrap"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,20"/>

                        <Button Name="AnswerButton0" Height="45" Click="AnswerButton_Click"/>
                        <Button Name="AnswerButton1" Height="45" Click="AnswerButton_Click"/>
                        <Button Name="AnswerButton2" Height="45" Click="AnswerButton_Click"/>
                        <Button Name="AnswerButton3" Height="45" Click="AnswerButton_Click"/>

                        <TextBlock Name="QuizFeedbackTextBlock"
                                   TextWrapping="Wrap"
                                   FontSize="16"
                                   Foreground="#38BDF8"
                                   Margin="0,20,0,0"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="3" Orientation="Horizontal">
                    <Button Content="Start Quiz"
                            Width="130"
                            Height="40"
                            Click="StartQuizButton_Click"/>

                    <Button Content="Next Question"
                            Width="150"
                            Height="40"
                            Click="NextQuestionButton_Click"/>
                </StackPanel>
            </Grid>

            <!-- ACTIVITY LOG PANEL -->
            <Grid Name="ActivityLogPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Activity Log"
                           FontSize="28"
                           FontWeight="Bold"
                           Margin="0,0,0,15"/>

                <DataGrid Name="ActivityLogDataGrid"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Margin="0,0,0,15">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding LogId}" Width="70"/>
                        <DataGridTextColumn Header="Action" Binding="{Binding ActionDescription}" Width="*"/>
                        <DataGridTextColumn Header="Date" Binding="{Binding ActionDate}" Width="180"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Button Grid.Row="2"
                        Content="Refresh Log"
                        Width="130"
                        Height="40"
                        HorizontalAlignment="Left"
                        Click="RefreshLogButton_Click"/>
            </Grid>

        </Grid>
    </Grid>
</Window>